datos <- data.frame(
entidad = c("Monstruo", "Humano"),
x = c(1, 2),  # Posición en el eje X
y = c(1, 1),  # Posición en el eje Y
peso = c(valor, 62),  # Tamaño de la burbuja
color = c("red", "blue")
)
# Crear gráfico de burbujas
p <- plotly::plot_ly(datos, x = ~x, y = ~y, text = ~entidad,
marker = list(size = ~peso / 2, color = ~color, opacity = 0.6),
type = "scatter", mode = "markers") |>
plotly::layout(title = "Comparación de Pesos con Burbujas",
xaxis = list(title = "", showticklabels = FALSE, showgrid = FALSE, zeroline = FALSE),
yaxis = list(title = "", showticklabels = FALSE, showgrid = FALSE, zeroline = FALSE),
showlegend = FALSE)
p
