pesos <- data.frame(
entidad = c(input$pokemon_init, "Human"),
peso = c(valor, 62)
)
# Crear gráfico de barras
p <- plotly::plot_ly(pesos, x = ~entidad, y = ~peso, type = "bar",
marker = list(color = c("red", "blue"))) |>
plotly::layout(title = "",
xaxis = list(title = "",  # Aumentar tamaño y negrilla
tickfont = list(size = 18, weight = "bold")),
yaxis = list(title = "Height (m)"))
p
