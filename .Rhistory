datos <- data.frame(
entidad = c("Pokemon", "Humano"),
x = c(0, 1),  # Posiciones en el eje X
y = c(0, 0),  # Mismo eje Y para superponer
radio = c(valor / 10, 62 / 10),  # Radio proporcional
color = c("red", "blue")
)
# Crear gráfico con círculos superpuestos
p <- plot_ly() |>
plotly::add_trace(
type = "scatter",
mode = "markers",
x = datos$x,
y = datos$y,
marker = list(
size = datos$radio * 2,  # Ajuste de tamaño visual
color = datos$color,
opacity = 0.5
)
) %>%
plotly::layout(
title = "",
xaxis = list(title = "",
showgrid = FALSE,
zeroline = FALSE,
showticklabels = FALSE),
yaxis = list(title = "",
showgrid = FALSE,
zeroline = FALSE,
showticklabels = FALSE),
showlegend = FALSE
)
# Crear gráfico con círculos superpuestos
