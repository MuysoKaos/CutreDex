input = list(pokemon_init = "Raichu",
pokemon_init_rival = "Snorlax")
init_sts = dataset |>
dplyr::filter(name == input$pokemon_init)
rival_sts = dataset |>
dplyr::filter(name == input$pokemon_init_rival)
init_punt = (max(init_sts$attack,init_sts$sp_attack)/max(rival_sts$defense,rival_sts$sp_defense))*(init_sts$speed/rival_sts$hp)
rival_punt = (max(rival_sts$attack,rival_sts$sp_attack)/max(init_sts$defense,init_sts$sp_defense))*(rival_sts$speed/init_sts$hp)
cols_hnd_rvl = paste0("against_",c(init_sts$type1,init_sts$type2))[paste0("against_",c(init_sts$type1,init_sts$type2)) != "against_"]
rival_handicap = tibble::tibble(rival_sts[,cols_hnd_rvl]) |>
tidyr::gather(type,val) |>
dplyr::summarise(val = mean(val,na.rm = T)) |>
dplyr::select(val) |>
dplyr::pull()
cols_hnd_init = paste0("against_",c(rival_sts$type1,rival_sts$type2))[paste0("against_",c(rival_sts$type1,rival_sts$type2)) != "against_"]
init_handicap = tibble::tibble(init_sts[,cols_hnd_init])  |>
tidyr::gather(type,val) |>
dplyr::summarise(val = mean(val,na.rm = T)) |>
dplyr::select(val) |>
dplyr::pull()
final = data.frame(init_punt = round(init_punt*init_handicap/(init_punt*init_handicap+rival_punt*rival_handicap)*100,2),
rival_punt = round(rival_punt*rival_handicap/(init_punt*init_handicap+rival_punt*rival_handicap)*100,2))
final
final |>
